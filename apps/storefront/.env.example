# Backend API base URL
VITE_SERVER_URL=http://localhost:3000

# PostHog public client config
VITE_PUBLIC_POSTHOG_KEY=your-posthog-project-api-key
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
