{
	"name": "@nexa/server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "bunx tsgo -b",
		"lint": "biome check .",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/index.ts",
		"seed:admin": "bun run src/scripts/seed-admin.ts",
		"start": "bun run dist/index.mjs",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"test:all": "vitest run && vitest run --config vitest.integration.config.ts"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.1",
		"@elysiajs/openapi": "^1.4.14",
		"@nexa/auth": "workspace:*",
		"@nexa/db": "workspace:*",
		"@nexa/env": "workspace:*",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"drizzle-orm": "1.0.0-beta.19",
		"elysia": "^1.4.28",
		"elysia-rate-limit": "^4.5.1",
		"neverthrow": "^8.2.0",
		"reflect-metadata": "^0.2.2",
		"tsyringe": "^4.10.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@nexa/config": "workspace:*",
		"@testcontainers/postgresql": "^11.13.0",
		"@types/bun": "catalog:",
		"@typescript/native-preview": "latest",
		"testcontainers": "^11.13.0",
		"tsdown": "^0.16.8",
		"vitest": "^4.1.1"
	}
}
