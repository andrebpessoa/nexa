{
	"name": "nexa",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.3.1",
			"zod": "^4.3.6",
			"@types/bun": "^1.3.11",
			"better-auth": "1.5.2",
			"lucide-react": "^0.546.0",
			"next-themes": "^0.4.6",
			"react": "^19.2.4",
			"react-dom": "^19.2.4",
			"sonner": "^2.0.7",
			"tailwindcss": "^4.2.2",
			"@types/react": "^19.2.14",
			"@types/react-dom": "^19.2.3"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"lint": "turbo run lint",
		"check-types": "turbo run check-types",
		"test": "turbo run test",
		"test:integration": "turbo run test:integration",
		"test:all": "turbo run test:all",
		"dev:admin": "turbo run dev --filter=@nexa/admin",
		"dev:server": "turbo run dev --filter=@nexa/server",
		"db:push": "turbo run db:push --filter=@nexa/db",
		"db:seed": "turbo run db:seed --filter=@nexa/db",
		"db:studio": "turbo run db:studio --filter=@nexa/db",
		"db:generate": "turbo run db:generate --filter=@nexa/db",
		"db:migrate": "turbo run db:migrate --filter=@nexa/db",
		"db:start": "turbo run db:start --filter=@nexa/db",
		"db:watch": "turbo run db:watch --filter=@nexa/db",
		"db:stop": "turbo run db:stop --filter=@nexa/db",
		"db:down": "turbo run db:down --filter=@nexa/db",
		"check": "biome check --write .",
		"format": "biome check --write --unsafe ."
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"@nexa/config": "workspace:*",
		"@types/bun": "catalog:",
		"@typescript/native-preview": "latest",
		"lefthook": "latest",
		"turbo": "^2.8.20"
	},
	"packageManager": "bun@1.3.11"
}
